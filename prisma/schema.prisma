// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// User roles
enum Role {
  ADMIN
  MODERATOR
  USER
}

// Server authentication types
enum ServerAuthType {
  PASSWORD
  SSH_KEY
}

// Server statuses
enum ServerStatus {
  PENDING
  SETTING_UP
  ONLINE
  OFFLINE
  ERROR
}

// Proxy statuses
enum ProxyStatus {
  CREATING
  ACTIVE
  EXPIRED
  ERROR
}

// Proxy IP types
enum ProxyIPType {
  IPv4
  IPv6
}

// Proxy protocols
enum ProxyType {
  HTTP
  SOCKS5
}

// Job types
enum JobType {
  SETUP_SERVER
  PROVISION_PROXY
  BULK_PROVISION_PROXY
  ROTATE_PROXY
  DELETE_PROXY
  EXPIRE_PROXY
  RESET_SERVER
  AUTOMATION
  SYNC_SERVER_PORT
  CHECK_GOOGLE
}

// Job statuses
enum JobStatus {
  WAITING
  ACTIVE
  COMPLETED
  FAILED
}

// Order statuses
enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// Transaction types
enum TransactionType {
  DEPOSIT
  PAYMENT
  REFUND
  BONUS
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String?
  role         Role          @default(USER)
  balance      Decimal       @default(0) @db.Decimal(10, 2)
  notificationsEnabled Boolean @default(true)
  emailVerified DateTime?
  verificationToken String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  proxies      Proxy[]
  orders       Order[]
  transactions Transaction[]
}

model Server {
  id                String         @id @default(cuid())
  name              String
  host              String
  port              Int            @default(22)
  username          String
  authType          ServerAuthType @default(PASSWORD)
  passwordEncrypted String?
  privateKey        String?        @db.Text
  provider          String?
  locationId        String?
  location          Location?      @relation(fields: [locationId], references: [id])
  ipv6              String?
  status            ServerStatus   @default(PENDING)
  maxProxies        Int            @default(100)
  startPort         Int            @default(10000)
  lastPort          Int?
  autoRotate        Boolean        @default(false)
  rotationInterval  Int            @default(0) // Minutes, 0 = disabled
  notes             String?        @db.Text
  subnets           ServerSubnet[]
  jobs              ServerJob[]
  proxies           Proxy[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([status])
  @@index([locationId])
}

model Location {
  id          String   @id @default(cuid())
  name        String   @unique
  countryCode String   // Ví dụ: VN, US, UK
  servers     Server[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServerSubnet {
  id        String   @id @default(cuid())
  serverId  String
  ipv6Range String   // Ví dụ: 2001:db8:a::/64
  status    String   @default("ACTIVE") // ACTIVE, BLOCKED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
}

model Proxy {
  id            String      @id @default(cuid())
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  serverId      String
  server        Server      @relation(fields: [serverId], references: [id])
  port          Int
  username      String
  password      String
  ipType        ProxyIPType @default(IPv6)
  ipv6          String?
  status        ProxyStatus @default(CREATING)
  proxyType     ProxyType   @default(SOCKS5)
  isEnabled     Boolean     @default(true)
  autoRenew     Boolean     @default(false)
  renewalDuration String    @default("1m")
  comment       String?     @db.Text
  expiresAt     DateTime?
  lastRotatedAt DateTime?
  jobs          ServerJob[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([serverId])
  @@index([status])
  @@index([expiresAt])
  @@unique([serverId, port])
}

model ServerJob {
  id         String    @id @default(cuid())
  type       JobType
  status     JobStatus @default(WAITING)
  serverId   String?
  server     Server?   @relation(fields: [serverId], references: [id])
  proxyId    String?
  proxy      Proxy?    @relation(fields: [proxyId], references: [id])
  logs       String?   @db.LongText
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([serverId])
  @@index([proxyId])
  @@index([status])
  @@index([type])
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  proxyId     String?
  totalAmount Decimal     @db.Decimal(10, 2)
  status      OrderStatus @default(PENDING)
  notes       String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  transaction Transaction?

  @@index([userId])
}

model Transaction {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  orderId   String?         @unique
  order     Order?          @relation(fields: [orderId], references: [id])
  amount    Decimal         @db.Decimal(10, 2)
  type      TransactionType
  status    String          @default("COMPLETED") // COMPLETED, PENDING, FAILED
  notes     String?         @db.Text
  createdAt DateTime        @default(now())

  @@index([userId])
}
